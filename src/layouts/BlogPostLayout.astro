---
import PageLayout from './PageLayout.astro';

interface Props {
  title: string;
  date: Date;
  author: string;
  tags?: string[];
  excerpt: string;
}

const { title, date, author, tags, excerpt } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Rough reading time estimate
const content = await Astro.slots.render('default');
const words = content.split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(words / 250));
---

<PageLayout title={title} description={excerpt} path={Astro.url.pathname}>
  <article class="max-w-3xl mx-auto px-8 py-20">
    <header class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xs tracking-widest uppercase text-forest">{author}</span>
        <span class="text-border">&middot;</span>
        <time class="text-sm text-faded" datetime={date.toISOString()}>{formattedDate}</time>
        <span class="text-border">&middot;</span>
        <span class="text-sm text-faded">{readingTime} min read</span>
      </div>
      <h1 class="font-serif text-4xl md:text-5xl font-medium text-ink leading-tight mb-4">{title}</h1>
      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {tags.map(tag => (
            <span class="font-mono text-[10px] tracking-widest uppercase px-3 py-1 bg-cream border border-border rounded-full text-forest-light">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>
    <div class="prose prose-lg max-w-none
      [&_h2]:font-serif [&_h2]:text-2xl [&_h2]:font-medium [&_h2]:text-ink [&_h2]:mt-12 [&_h2]:mb-4
      [&_h3]:font-serif [&_h3]:text-xl [&_h3]:font-medium [&_h3]:text-ink [&_h3]:mt-8 [&_h3]:mb-3
      [&_p]:text-muted [&_p]:leading-relaxed [&_p]:mb-6
      [&_a]:text-forest [&_a]:underline [&_a]:underline-offset-2 hover:[&_a]:text-forest-dark
      [&_ul]:text-muted [&_ul]:leading-relaxed [&_ul]:mb-6 [&_ul]:list-disc [&_ul]:pl-6
      [&_ol]:text-muted [&_ol]:leading-relaxed [&_ol]:mb-6 [&_ol]:list-decimal [&_ol]:pl-6
      [&_blockquote]:border-l-4 [&_blockquote]:border-sand [&_blockquote]:pl-6 [&_blockquote]:italic [&_blockquote]:text-earth
      [&_code]:font-mono [&_code]:text-sm [&_code]:bg-cream [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded
    ">
      <slot />
    </div>
  </article>
</PageLayout>
