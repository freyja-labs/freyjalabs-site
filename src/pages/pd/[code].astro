---
/**
 * /pd/[code].astro — Dynamic district portal page
 * Reads from /src/data/district-portals.json
 * Route: freyjalabs.com/pd/77092-hisd, freyjalabs.com/pd/27518-wcpss, etc.
 */
import PageLayout from '../../layouts/PageLayout.astro';
import SectionLabel from '../../components/ui/SectionLabel.astro';
import DistrictMap from '../../components/icons/DistrictMap.astro';
import FeedbackCallout from '../../components/ui/FeedbackCallout.astro';
import StickyNav from '../../components/ui/StickyNav.astro';
import districtData from '../../data/district-portals.json';

export function getStaticPaths() {
  return Object.keys(districtData.districts).map(code => ({
    params: { code },
    props: {
      district: districtData.districts[code],
      meta: districtData.meta,
      states: districtData.states,
      stateContext: (districtData as any).stateContext?.[districtData.districts[code].state] || null,
    }
  }));
}

const { code } = Astro.params;
const { district, meta, states, stateContext } = Astro.props;
const { brand } = meta;
const stateStandards = states[district.state] || {};
const techLesson = district.lessons.tech;
const unpluggedLesson = district.lessons.unplugged;
const lessons = [
  { kind: 'tech', lesson: techLesson, accent: 'forest' },
  unpluggedLesson ? { kind: 'unplugged', lesson: unpluggedLesson, accent: 'earth' } : null,
].filter(Boolean);

const tierAccent: Record<string, string> = {
  cohort: 'border-forest/30 bg-forest/[0.04]',
  building: 'border-forest/30 bg-forest/[0.04]',
  institute: 'border-forest/40 bg-forest/[0.06]',
  leadership: 'border-earth/30 bg-earth/[0.04]',
  coaching: 'border-clay/30 bg-clay/[0.04]',
};
---

<PageLayout
  title={`${district.district} — Professional Development`}
  description={`Customized, hands-on professional development for ${district.district}. AI literacy, STEM integration, and computational thinking workshops built for your teachers and students.`}
  path={`/pd/${code}`}
>
  <!-- HERO with animated district map -->
  <section id="top" class="relative overflow-hidden bg-warm-white">
    <div class="absolute inset-0 z-0">
      <DistrictMap code={code} class="h-full w-full" label={`Animated street map of ${district.city}, ${district.state}`} />
    </div>
    <div class="relative z-10 px-8 pt-24 pb-28">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-block bg-warm-white/90 backdrop-blur-sm rounded-2xl px-8 py-10 border border-border/60 shadow-sm">
          <SectionLabel>{brand.name}</SectionLabel>
          <h1 class="font-serif text-4xl md:text-5xl font-medium text-ink leading-tight mb-6">
            Professional Development for {district.district}
          </h1>
          <p class="font-serif text-[22px] text-earth italic mb-4">
            Customized. Hands-on. Built for your teachers and your students.
          </p>
          <p class="text-[15px] text-muted">
            {district.city}, {district.state} · {district.enrollment?.toLocaleString()} students
          </p>
        </div>
      </div>
    </div>
    <p class="relative z-10 text-center text-[10px] font-mono tracking-widest uppercase text-faded/70 pb-3">
      Map data © OpenStreetMap contributors
    </p>
  </section>

  <!-- STICKY NAV — pins under hero, jump anywhere from anywhere -->
  <StickyNav districtName={district.district} hasUnplugged={!!unpluggedLesson} />

  <!-- CONTEXT — synthesized narrative reading of the district -->
  <section id="context" class="px-8 py-24 scroll-mt-20">
    <div class="max-w-3xl mx-auto">
      <SectionLabel>What we've been reading</SectionLabel>
      <h2 class="font-serif text-3xl md:text-[42px] font-medium text-ink leading-tight mb-10">
        From outside, what we notice
      </h2>

      {district.contextNarrative ? (
        <div class="prose-narrative">
          <p class="font-serif text-[20px] md:text-[22px] leading-[1.65] text-ink first-letter:font-serif first-letter:text-[64px] first-letter:font-semibold first-letter:text-forest first-letter:float-left first-letter:leading-[0.85] first-letter:mr-3 first-letter:mt-2">
            {district.contextNarrative}
          </p>
        </div>
      ) : district.connectionPoint && (
        <p class="font-serif text-[19px] leading-relaxed text-muted">
          {district.connectionPoint}
        </p>
      )}

      <!-- Soft blog touchpoints + nav hint -->
      <div class="mt-14 pt-8 border-t border-border/60">
        <p class="font-mono text-[10px] tracking-widest uppercase text-faded mb-3">If any of this resonates, you might also like</p>
        <ul class="space-y-1.5 mb-8">
          <li class="text-[14px] leading-relaxed text-muted">
            <a href="/blog/ai-literacy-not-future-problem" class="text-forest hover:text-forest-dark underline-offset-4 hover:underline">AI literacy is not a future problem</a> — what your teachers are already encountering, whether the standards have arrived or not.
          </li>
          <li class="text-[14px] leading-relaxed text-muted">
            <a href="/blog/research-team-vs-pd-vendor" class="text-forest hover:text-forest-dark underline-offset-4 hover:underline">What a research team brings that a PD vendor cannot</a> — why we don't sell pre-built curriculum.
          </li>
        </ul>
        <p class="text-center font-mono text-[10px] tracking-widest uppercase text-faded">
          Next ↓ <a href="#lessons" class="text-forest hover:text-forest-dark underline-offset-4 hover:underline">02 · Sample lessons</a>
        </p>
      </div>
    </div>
  </section>

  <!-- SAMPLE LESSONS — framed as artifacts, not deliverables -->
  <section id="lessons" class="bg-warm-white px-8 py-24 scroll-mt-20">
    <div class="max-w-4xl mx-auto">
      <SectionLabel>Sample lessons — artifacts, not deliverables</SectionLabel>
      <h2 class="font-serif text-3xl md:text-[42px] font-medium text-ink leading-tight mb-6">
        We don't deliver lesson plans.
      </h2>
      <p class="text-[18px] leading-relaxed text-ink mb-5 max-w-3xl">
        We deliver change for your teachers. The lessons below are the receipts.
      </p>
      <p class="text-[16px] leading-relaxed text-muted mb-14 max-w-3xl">
        These two examples were built for {district.district} — but what we'll actually do together depends on what you tell us about where you are and where you want to go. We custom-build with your teachers around what your students, your community, and your district leadership are actually navigating: AI integration, CS/STEM integration, {district.state} policy, the local context only your educators can read. The artifacts you'll see below are one shape that capability can take.
      </p>

      {lessons.map(({ kind, lesson, accent }) => {
        const accentClasses = accent === 'forest'
          ? { card: 'border-forest/30', tag: 'text-forest-light bg-forest/10', objBullet: 'before:bg-forest', aiBorder: 'border-forest/20', aiText: 'text-forest', aiBullet: 'before:bg-forest-light', protoBg: 'bg-forest/5 border-forest/15', protoText: 'text-forest', protoTag: 'text-forest', meta: 'text-forest', accentBar: 'bg-forest' }
          : { card: 'border-earth/30', tag: 'text-earth bg-earth/10', objBullet: 'before:bg-earth', aiBorder: 'border-forest/20', aiText: 'text-forest', aiBullet: 'before:bg-forest-light', protoBg: 'bg-forest/5 border-forest/15', protoText: 'text-forest', protoTag: 'text-forest', meta: 'text-earth', accentBar: 'bg-earth' };
        const tm = lesson.teacher_materials;
        const lessonId = `lesson-${kind}`;
        const kindLabel = kind === 'tech' ? 'Tech lesson' : 'Unplugged lesson';
        return (
          <article id={lessonId} class={`relative scroll-mt-20 mb-8 bg-cream border-2 ${accentClasses.card} rounded-lg overflow-hidden`}>
            {/* Accent bar */}
            <div class={`absolute left-0 top-0 bottom-0 w-1 ${accentClasses.accentBar}`}></div>

            {/* Always-visible card header — the executive summary */}
            <div class="p-9">
              <div class="flex items-baseline gap-3 mb-3">
                <span class={`font-mono text-[10px] tracking-widest uppercase font-semibold ${accentClasses.meta}`}>{kindLabel}</span>
                <span class="font-mono text-[10px] tracking-widest uppercase text-faded">/ {kind === 'tech' ? 'with devices' : 'no screens'}</span>
              </div>
              <span class={`inline-block font-mono text-[10px] tracking-widest uppercase ${accentClasses.tag} px-3 py-1 rounded mb-4`}>
                {lesson.badge}
              </span>
              <h3 class="font-serif text-[26px] font-semibold text-ink mb-2">{lesson.title}</h3>
              <p class="font-mono text-xs tracking-widest uppercase text-earth mb-6">
                {lesson.grade_band} · {lesson.subjects.join(' / ')} · {lesson.duration_minutes} minutes
              </p>

              {lesson.district_framing ? (
                <p class="font-serif text-[18px] leading-relaxed text-ink mb-8">{lesson.district_framing}</p>
              ) : (
                <p class="text-[17px] leading-relaxed text-muted mb-8">{lesson.overview}</p>
              )}

              {lesson.distinction && (
                <div class="mb-2 p-6 bg-forest/[0.06] border-l-4 border-forest rounded-r-lg">
                  <div class="flex items-baseline gap-2 mb-2">
                    <span class="font-mono text-[10px] tracking-widest uppercase text-forest font-semibold">What's new</span>
                    <span class="font-mono text-[10px] tracking-widest uppercase text-faded">— what wouldn't have happened before this PD</span>
                  </div>
                  <p class="font-serif text-[17px] leading-[1.55] text-ink">{lesson.distinction}</p>
                </div>
              )}
            </div>

            {/* Collapsible full lesson plan */}
            <details class="lesson-details group">
              <summary class={`lesson-summary border-t-2 border-dashed ${accentClasses.card} px-9 py-5 cursor-pointer hover:bg-warm-white/60 transition-colors`}>
                <span class="flex items-center justify-between gap-3">
                  <span class="flex items-baseline gap-3">
                    <span class={`font-mono text-[10px] tracking-widest uppercase font-semibold ${accentClasses.meta}`}>Show full lesson plan</span>
                    <span class="font-mono text-[10px] tracking-widest uppercase text-faded">objectives · procedure · materials · assessment{tm ? ' · teacher pack' : ''}</span>
                  </span>
                  <span class="lesson-chevron font-mono text-[14px] text-faded group-open:rotate-180 transition-transform">▾</span>
                </span>
              </summary>

              <div class="lesson-body px-9 pb-9 pt-6">

              {/* Sub-nav within lesson */}
              {(() => {
                const chipBase = `text-[11px] font-mono tracking-widest uppercase font-semibold px-3.5 py-1.5 rounded-full border-2 transition-all`;
                const chipColor = accent === 'forest'
                  ? `bg-forest/[0.08] text-forest border-forest/30 hover:bg-forest hover:text-warm-white hover:border-forest hover:-translate-y-0.5`
                  : `bg-earth/[0.08] text-earth border-earth/30 hover:bg-earth hover:text-warm-white hover:border-earth hover:-translate-y-0.5`;
                return (
                  <nav class="lesson-subnav flex flex-wrap gap-2 mb-8 pb-4 border-b-2 border-dashed border-border" aria-label={`${lesson.title} sections`}>
                    <span class="inline-flex items-center font-mono text-[10px] tracking-widest uppercase text-faded mr-1">Jump to:</span>
                    <a href={`#${lessonId}-objectives`} class={`${chipBase} ${chipColor}`}>Objectives</a>
                    <a href={`#${lessonId}-procedure`} class={`${chipBase} ${chipColor}`}>Procedure</a>
                    {kind === 'tech' && lesson.check_the_machine && (
                      <a href={`#${lessonId}-protocol`} class={`${chipBase} ${chipColor}`}>Verification protocol</a>
                    )}
                    <a href={`#${lessonId}-materials`} class={`${chipBase} ${chipColor}`}>Materials</a>
                    <a href={`#${lessonId}-assessment`} class={`${chipBase} ${chipColor}`}>Assessment</a>
                    {tm && (
                      <a href={`#${lessonId}-teacher-pack`} class={`text-[11px] font-mono tracking-widest uppercase font-semibold px-3.5 py-1.5 rounded-full border-2 bg-forest text-warm-white border-forest hover:bg-forest-dark hover:-translate-y-0.5 transition-all`}>Teacher pack ✦</a>
                    )}
                  </nav>
                );
              })()}

              <div id={`${lessonId}-objectives`} class="grid md:grid-cols-2 gap-6 mb-8 scroll-mt-32">
              <div class="p-6 bg-warm-white border border-border rounded-lg">
                <h4 class="font-sans text-[15px] font-semibold text-ink mb-3">Content Objectives</h4>
                <ul class="space-y-2">
                  {lesson.content_objectives.map(obj => (
                    <li class={`text-[15px] leading-relaxed text-muted pl-4 relative before:content-[''] before:absolute before:left-0 before:top-[10px] before:w-1.5 before:h-1.5 ${accentClasses.objBullet} before:rounded-full`}>{obj}</li>
                  ))}
                </ul>
              </div>
              <div class={`p-6 bg-warm-white border ${accentClasses.aiBorder} rounded-lg`}>
                <h4 class={`font-sans text-[15px] font-semibold ${accentClasses.aiText} mb-3`}>AI Literacy Objectives</h4>
                <ul class="space-y-2">
                  {lesson.ai_literacy_objectives.map(obj => (
                    <li class={`text-[15px] leading-relaxed text-muted pl-4 relative before:content-[''] before:absolute before:left-0 before:top-[10px] before:w-1.5 before:h-1.5 ${accentClasses.aiBullet} before:rounded-full`}>{obj}</li>
                  ))}
                </ul>
              </div>
            </div>

            <h4 id={`${lessonId}-procedure`} class="font-sans text-[15px] font-semibold text-ink mb-4 scroll-mt-32">
              {kind === 'unplugged' ? 'What Students Do — No Screens, No Devices' : 'What Students Do'}
            </h4>
            <div class="space-y-4 mb-8">
              {lesson.procedure.map(phase => {
                const note = tm?.facilitation_notes?.find(n => n.phase === phase.phase);
                return (
                  <div class="p-5 bg-warm-white border border-border rounded-lg">
                    <span class="font-mono text-[10px] tracking-widest uppercase text-earth">
                      Phase {phase.phase} · {phase.duration_minutes} min
                    </span>
                    <strong class="block font-sans text-[15px] font-semibold text-ink mt-1 mb-1">{phase.title}</strong>
                    <p class="text-[15px] leading-relaxed text-muted">{phase.description}</p>
                    {note && (
                      <div class="mt-4 pt-4 border-t border-border/60">
                        <span class="font-mono text-[10px] tracking-widest uppercase text-forest mb-2 block">Facilitation focus</span>
                        <p class="text-[14px] leading-relaxed text-muted mb-3">{note.focus}</p>
                        <span class="font-mono text-[10px] tracking-widest uppercase text-clay mb-2 block">Watch for</span>
                        <p class="text-[14px] leading-relaxed text-muted italic">{note.watch_for}</p>
                      </div>
                    )}
                  </div>
                );
              })}
            </div>

            {kind === 'tech' && lesson.check_the_machine && (
              <div id={`${lessonId}-protocol`} class={`p-6 ${accentClasses.protoBg} border rounded-lg mb-8 scroll-mt-32`}>
                <h4 class={`font-sans text-[15px] font-semibold ${accentClasses.protoText} mb-1`}>A four-step verification protocol your teachers will build with us</h4>
                <p class="text-[13px] leading-relaxed text-muted mb-5">A practice students learn once and apply to any AI output, in any subject, for the rest of their lives.</p>
                <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
                  {lesson.check_the_machine.map(step => (
                    <div class="p-4 bg-warm-white rounded-lg border border-border">
                      <strong class={`block font-mono text-[11px] tracking-widest uppercase ${accentClasses.protoTag} mb-2`}>
                        {step.step}. {step.label}
                      </strong>
                      <p class="text-[14px] leading-relaxed text-muted">{step.prompt}</p>
                    </div>
                  ))}
                </div>
                <p class="mt-5 text-[12px] text-faded italic">
                  More on the thinking behind this — <a href="/blog/craft-series-cxedhub" class="text-forest hover:text-forest-dark underline-offset-4 underline">the framework we built it from</a>.
                </p>
              </div>
            )}

            <div class="grid md:grid-cols-2 gap-6">
              <div id={`${lessonId}-materials`} class="scroll-mt-32">
                <h4 class="font-sans text-[15px] font-semibold text-ink mb-3">Materials</h4>
                <ul class="space-y-1.5">
                  {lesson.materials.map(m => (
                    <li class="text-[15px] leading-relaxed text-muted pl-4 relative before:content-[''] before:absolute before:left-0 before:top-[10px] before:w-1.5 before:h-1.5 before:bg-sand before:rounded-full">{m}</li>
                  ))}
                </ul>
              </div>
              <div id={`${lessonId}-assessment`} class="scroll-mt-32">
                <h4 class="font-sans text-[15px] font-semibold text-ink mb-3">Assessment</h4>
                <p class="text-[15px] leading-relaxed text-muted mb-2">{lesson.assessment.description}</p>
                {lesson.assessment.criteria && (
                  <p class="text-[14px] leading-relaxed text-faded italic">{lesson.assessment.criteria}</p>
                )}
              </div>
            </div>

            {/* TEACHER MATERIALS — only renders when present */}
            {tm && (
              <div id={`${lessonId}-teacher-pack`} class="mt-10 pt-10 border-t-2 border-dashed border-border scroll-mt-32">
                <div class="flex items-baseline gap-3 mb-2">
                  <span class="font-mono text-[10px] tracking-widest uppercase text-forest">Teacher pack</span>
                  <span class="font-mono text-[10px] tracking-widest uppercase text-faded">— everything you need to teach this</span>
                </div>
                <h4 class="font-serif text-[22px] font-semibold text-ink mb-6">For the Facilitator</h4>

                <div class="grid md:grid-cols-2 gap-6 mb-8">
                  {tm.prior_knowledge && (
                    <div class="p-6 bg-warm-white border border-border rounded-lg">
                      <h5 class="font-sans text-[14px] font-semibold text-ink mb-3">Prior Knowledge Required</h5>
                      <ul class="space-y-1.5">
                        {tm.prior_knowledge.map(p => (
                          <li class="text-[14px] leading-relaxed text-muted pl-4 relative before:content-[''] before:absolute before:left-0 before:top-[8px] before:w-1.5 before:h-1.5 before:bg-earth before:rounded-full">{p}</li>
                        ))}
                      </ul>
                    </div>
                  )}
                  {tm.exit_ticket && (
                    <div class="p-6 bg-warm-white border border-forest/20 rounded-lg">
                      <h5 class="font-sans text-[14px] font-semibold text-forest mb-3">Exit Ticket</h5>
                      <p class="text-[14px] leading-relaxed text-ink italic mb-3">"{tm.exit_ticket.prompt}"</p>
                      <span class="font-mono text-[10px] tracking-widest uppercase text-faded mb-2 block">Look for</span>
                      <ul class="space-y-1">
                        {tm.exit_ticket.look_for.map(l => (
                          <li class="text-[13px] leading-relaxed text-muted pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-forest">{l}</li>
                        ))}
                      </ul>
                    </div>
                  )}
                </div>

                {tm.misconceptions && (
                  <div class="mb-8">
                    <h5 class="font-sans text-[14px] font-semibold text-ink mb-4">Anticipated Misconceptions</h5>
                    <div class="space-y-3">
                      {tm.misconceptions.map(m => (
                        <div class="p-5 bg-warm-white border border-border rounded-lg">
                          <p class="text-[14px] leading-relaxed text-clay font-serif italic mb-2">{m.misconception}</p>
                          <p class="text-[14px] leading-relaxed text-muted"><strong class="text-forest">→</strong> {m.response}</p>
                        </div>
                      ))}
                    </div>
                  </div>
                )}

                {tm.differentiation && (
                  <div class="mb-8">
                    <h5 class="font-sans text-[14px] font-semibold text-ink mb-4">Differentiation</h5>
                    <div class="grid md:grid-cols-2 gap-4">
                      <div class="p-5 bg-warm-white border border-border rounded-lg">
                        <span class="font-mono text-[10px] tracking-widest uppercase text-earth mb-2 block">Below grade</span>
                        <p class="text-[14px] leading-relaxed text-muted">{tm.differentiation.below_grade}</p>
                      </div>
                      <div class="p-5 bg-warm-white border border-border rounded-lg">
                        <span class="font-mono text-[10px] tracking-widest uppercase text-earth mb-2 block">At grade</span>
                        <p class="text-[14px] leading-relaxed text-muted">{tm.differentiation.at_grade}</p>
                      </div>
                      <div class="p-5 bg-warm-white border border-border rounded-lg">
                        <span class="font-mono text-[10px] tracking-widest uppercase text-earth mb-2 block">Above grade</span>
                        <p class="text-[14px] leading-relaxed text-muted">{tm.differentiation.above_grade}</p>
                      </div>
                      {tm.differentiation.multilingual_learners && (
                        <div class="p-5 bg-warm-white border border-forest/20 rounded-lg">
                          <span class="font-mono text-[10px] tracking-widest uppercase text-forest mb-2 block">Multilingual learners</span>
                          <p class="text-[14px] leading-relaxed text-muted">{tm.differentiation.multilingual_learners}</p>
                        </div>
                      )}
                    </div>
                  </div>
                )}

                {tm.slide_cues && (
                  <div class="mb-8">
                    <h5 class="font-sans text-[14px] font-semibold text-ink mb-4">Slide Cues — {tm.slide_cues.length} slides</h5>
                    <div class="grid sm:grid-cols-2 gap-3">
                      {tm.slide_cues.map(s => (
                        <div class="p-4 bg-warm-white border border-border rounded-lg">
                          <span class="font-mono text-[10px] tracking-widest uppercase text-faded">Slide {s.slide}</span>
                          <strong class="block font-sans text-[14px] font-semibold text-ink mt-1 mb-2">{s.title}</strong>
                          <ul class="space-y-1">
                            {s.talking_points.map(tp => (
                              <li class="text-[13px] leading-relaxed text-muted pl-3 relative before:content-['·'] before:absolute before:left-0 before:text-forest">{tp}</li>
                            ))}
                          </ul>
                        </div>
                      ))}
                    </div>
                  </div>
                )}

                {tm.standards_alignment && (
                  <div class="mb-8">
                    <h5 class="font-sans text-[14px] font-semibold text-ink mb-4">Standards Alignment</h5>
                    <div class="space-y-2">
                      {tm.standards_alignment.map(s => (
                        <div class="p-4 bg-warm-white border border-border rounded-lg">
                          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-1">
                            <span class="font-mono text-[11px] tracking-widest uppercase text-forest">{s.framework}</span>
                            <span class="font-mono text-[11px] text-clay">{s.code}</span>
                          </div>
                          <p class="text-[14px] leading-relaxed text-muted">{s.text}</p>
                        </div>
                      ))}
                    </div>
                  </div>
                )}

                {tm.family_letter && (
                  <div class="p-6 bg-cream border-l-4 border-forest rounded">
                    <span class="font-mono text-[10px] tracking-widest uppercase text-forest mb-3 block">Family / Guardian Letter — copy & paste, edit to fit</span>
                    <p class="font-serif text-[15px] leading-relaxed text-ink whitespace-pre-line">{tm.family_letter}</p>
                  </div>
                )}
              </div>
            )}

              {/* Bottom-of-LP navigation: top of LP / next LP or section */}
              <div class="lesson-bottom-nav mt-10 pt-6 border-t-2 border-dashed border-border flex flex-wrap items-center justify-between gap-3">
                <a href={`#${lessonId}`} class={`inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-warm-white border-2 ${accentClasses.card} ${accentClasses.meta} font-mono text-[11px] tracking-widest uppercase font-semibold hover:bg-cream transition-colors`}>
                  ↑ Top of {kindLabel}
                </a>
                <a href="#lessons" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-warm-white border-2 border-border text-muted font-mono text-[11px] tracking-widest uppercase hover:border-forest hover:text-forest transition-colors">
                  ↑ Top of Lessons
                </a>
                {kind === 'tech' && unpluggedLesson ? (
                  <a href="#lesson-unplugged" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-earth text-warm-white font-mono text-[11px] tracking-widest uppercase font-semibold hover:bg-earth-light transition-colors">
                    Next: Unplugged Lesson →
                  </a>
                ) : (
                  <a href="#engagements" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-forest text-warm-white font-mono text-[11px] tracking-widest uppercase font-semibold hover:bg-forest-dark transition-colors">
                    Next: How we'd work together →
                  </a>
                )}
              </div>

              </div>
            </details>
          </article>
        );
      })}

      <!-- Closing reminder — artifacts vs. deliverables -->
      <div class="mt-12 p-8 bg-forest/[0.05] border border-forest/15 rounded-lg">
        <p class="font-serif text-[20px] md:text-[22px] leading-[1.5] text-ink italic">
          Worth saying again: the lessons above are receipts, not the goal. The point of the engagement is change for your teachers — their confidence to design the next ten lessons themselves, for whatever {district.district} faces next. We don't deliver lesson plans. We deliver capability.
        </p>
      </div>

      <!-- Soft blog touchpoints + nav hint -->
      <div class="mt-12 pt-8 border-t border-border/60">
        <p class="font-mono text-[10px] tracking-widest uppercase text-faded mb-3">More on how we think about this work</p>
        <ul class="space-y-1.5 mb-8">
          <li class="text-[14px] leading-relaxed text-muted">
            <a href="/blog/time-for-practice" class="text-forest hover:text-forest-dark underline-offset-4 hover:underline">"I need time for practice" — three words that reshape every PD</a> — what 60 teachers told us they actually need.
          </li>
          <li class="text-[14px] leading-relaxed text-muted">
            <a href="/blog/microcredentials-that-stick" class="text-forest hover:text-forest-dark underline-offset-4 hover:underline">Microcredentials that stick</a> — designing self-paced PD teachers actually finish.
          </li>
        </ul>
        <p class="text-center font-mono text-[10px] tracking-widest uppercase text-faded">
          Next ↓ <a href="#engagements" class="text-forest hover:text-forest-dark underline-offset-4 hover:underline">03 · How we'd work together</a>
        </p>
      </div>
    </div>
  </section>

  <!-- ENGAGEMENT OPTIONS -->
  <section id="engagements" class="px-8 py-24 scroll-mt-20">
    <div class="max-w-5xl mx-auto">
      <SectionLabel>Engagement Options</SectionLabel>
      <h2 class="font-serif text-3xl md:text-[42px] font-medium text-ink leading-tight mb-4">
        How We Can Work Together
      </h2>
      <p class="text-[17px] leading-relaxed text-muted mb-12 max-w-3xl">
        We don't sell a packaged curriculum — every engagement is shaped around what your district tells us it needs. The options below are starting shapes; the actual work gets co-designed with your team. Click any that look promising and tell us what you're thinking.
      </p>
      <p class="text-[14px] leading-relaxed text-muted mb-6 max-w-3xl">
        <span class="font-mono text-[10px] tracking-widest uppercase text-forest font-semibold">Click any option below to mark it as interesting</span> — then use the form to send a quick note.
      </p>

      <div class="engagement-grid grid md:grid-cols-2 gap-5">
        {district.engagementOptions.map(opt => {
          const accent = tierAccent[opt.tier] || 'border-border bg-warm-white';
          return (
            <button
              type="button"
              data-engagement-id={opt.id}
              data-engagement-name={opt.name}
              class={`engagement-option text-left p-7 border-2 rounded-lg ${accent} hover:-translate-y-1 hover:shadow-lg transition-all duration-200 cursor-pointer relative`}
              aria-pressed="false"
            >
              <span class="engagement-check absolute top-4 right-4 w-6 h-6 rounded-full border-2 border-border flex items-center justify-center transition-all">
                <svg class="checkmark w-3.5 h-3.5 text-warm-white opacity-0 transition-opacity" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="3 8 7 12 13 4"/>
                </svg>
              </span>
              <div class="flex items-baseline justify-between gap-3 mb-1 pr-8">
                <h3 class="font-serif text-[22px] font-semibold text-ink">{opt.name}</h3>
                <span class="font-mono text-[10px] tracking-widest uppercase text-faded shrink-0">{opt.duration}</span>
              </div>
              <p class="font-mono text-[11px] tracking-widest uppercase text-forest mb-4">{opt.participants}</p>
              <p class="text-[15px] leading-relaxed text-muted mb-4">{opt.description}</p>
              <p class="text-[14px] leading-relaxed text-muted">
                <strong class="text-ink">What you get:</strong> {opt.deliverables}
              </p>
            </button>
          );
        })}

        {/* 6th box — inline contact form */}
        <form
          id="engagement-contact-form"
          class="md:col-span-2 lg:col-span-1 p-7 border-2 border-forest bg-forest text-warm-white rounded-lg flex flex-col gap-3"
          data-formspree="https://formspree.io/f/mnjwnjee"
          data-district-code={code}
          data-district-name={district.district}
        >
          <div class="flex items-baseline justify-between gap-3 mb-1">
            <h3 class="font-serif text-[22px] font-semibold text-warm-white">Start a conversation</h3>
            <span class="font-mono text-[10px] tracking-widest uppercase text-warm-white/60 shrink-0">15 min reply</span>
          </div>
          <p class="font-mono text-[11px] tracking-widest uppercase text-warm-white/85 mb-2">
            <span id="selection-summary">No options selected — that's fine</span>
          </p>
          <div class="grid sm:grid-cols-2 gap-3">
            <input type="text" name="name" placeholder="Your name" required
              class="px-3 py-2 bg-warm-white/10 border border-warm-white/30 rounded text-warm-white placeholder-warm-white/50 text-[14px] focus:outline-none focus:border-warm-white focus:bg-warm-white/15 transition-colors" />
            <input type="email" name="email" placeholder="Your email" required
              class="px-3 py-2 bg-warm-white/10 border border-warm-white/30 rounded text-warm-white placeholder-warm-white/50 text-[14px] focus:outline-none focus:border-warm-white focus:bg-warm-white/15 transition-colors" />
          </div>
          <textarea name="message" rows="3" placeholder="What's on your mind? Even a few words helps us reply usefully."
            class="px-3 py-2 bg-warm-white/10 border border-warm-white/30 rounded text-warm-white placeholder-warm-white/50 text-[14px] focus:outline-none focus:border-warm-white focus:bg-warm-white/15 transition-colors resize-none"></textarea>
          <input type="hidden" name="interested_in" id="interested-in-field" value="" />
          <input type="hidden" name="district_code" value={code} />
          <input type="hidden" name="district_name" value={district.district} />
          <input type="hidden" name="_subject" value={`District inquiry — ${district.district}`} />
          <div class="flex items-center justify-between gap-3 mt-1">
            <span id="form-status" class="font-mono text-[10px] tracking-widest uppercase text-warm-white/70"></span>
            <button type="submit"
              class="px-5 py-2 bg-warm-white text-forest font-sans font-semibold text-[13px] rounded hover:bg-cream transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
              Send
            </button>
          </div>
        </form>
      </div>

      <!-- Navigation hint at section end -->
      <p class="mt-12 text-center font-mono text-[10px] tracking-widest uppercase text-faded">
        Next ↓ <a href="#cta" class="text-forest hover:text-forest-dark underline-offset-4 hover:underline">04 · Reach out</a>
      </p>
    </div>

    <script>
      (function() {
        const form = document.getElementById('engagement-contact-form');
        if (!form) return;
        const buttons = document.querySelectorAll('.engagement-option');
        const summary = document.getElementById('selection-summary');
        const hiddenField = document.getElementById('interested-in-field');
        const statusEl = document.getElementById('form-status');
        const submit = form.querySelector('button[type="submit"]');
        const selected = new Set();

        function refresh() {
          hiddenField.value = Array.from(selected).map(s => s.id).join(', ');
          if (selected.size === 0) {
            summary.textContent = "No options selected — that's fine";
          } else if (selected.size === 1) {
            const only = [...selected][0];
            summary.textContent = `Interested in: ${only.name}`;
          } else {
            summary.textContent = `Interested in ${selected.size} options`;
          }
        }

        buttons.forEach((btn) => {
          btn.addEventListener('click', () => {
            const id = btn.dataset.engagementId;
            const name = btn.dataset.engagementName;
            const isSelected = btn.getAttribute('aria-pressed') === 'true';
            if (isSelected) {
              selected.forEach(s => { if (s.id === id) selected.delete(s); });
              btn.setAttribute('aria-pressed', 'false');
              btn.classList.remove('is-selected');
            } else {
              selected.add({ id, name });
              btn.setAttribute('aria-pressed', 'true');
              btn.classList.add('is-selected');
            }
            refresh();
          });
        });

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          submit.disabled = true;
          statusEl.textContent = 'Sending…';
          const formData = new FormData(form);
          const payload = Object.fromEntries(formData.entries());
          payload.page_url = window.location.href;
          try {
            const res = await fetch(form.dataset.formspree, {
              method: 'POST',
              headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
              body: JSON.stringify(payload),
            });
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            statusEl.textContent = 'Sent. We\'ll be in touch.';
            form.querySelector('input[name="name"]').value = '';
            form.querySelector('input[name="email"]').value = '';
            form.querySelector('textarea[name="message"]').value = '';
            selected.clear();
            buttons.forEach(b => { b.setAttribute('aria-pressed', 'false'); b.classList.remove('is-selected'); });
            refresh();
            setTimeout(() => { submit.disabled = false; statusEl.textContent = ''; }, 4000);
          } catch (err) {
            console.error(err);
            statusEl.textContent = 'Could not send. Please try again.';
            submit.disabled = false;
          }
        });
      })();
    </script>

    <style>
      .engagement-option.is-selected {
        border-color: var(--color-forest);
        background-color: rgba(61, 107, 79, 0.1);
        transform: translateY(-2px);
        box-shadow: 0 8px 22px rgba(28, 28, 28, 0.12);
      }
      .engagement-option.is-selected .engagement-check {
        background-color: var(--color-forest);
        border-color: var(--color-forest);
      }
      .engagement-option.is-selected .checkmark {
        opacity: 1;
      }
    </style>
    </div>
  </section>

  <!-- CLOSING / CTA -->
  <section id="cta" class="bg-forest px-8 py-24 scroll-mt-20">
    <div class="max-w-3xl mx-auto text-center">
      <p class="font-serif text-[22px] md:text-[26px] text-warm-white leading-snug mb-8 italic">
        {meta.closing_line}
      </p>
      <div class="flex flex-col items-center gap-2 mb-6">
        {brand.founders.map(f => (
          <p class="text-white/75 text-[15px]">{f.name}, {f.credential}</p>
        ))}
      </div>
      <p class="font-serif text-[20px] text-warm-white font-medium mb-6">{brand.tagline}</p>
      <a
        href="mailto:hello@freyjalabs.com"
        class="inline-block rounded-md font-sans font-semibold transition-all duration-200 text-center bg-warm-white text-forest px-10 py-4 text-base hover:-translate-y-0.5 hover:shadow-lg"
      >
        hello@freyjalabs.com
      </a>
    </div>
  </section>

  <FeedbackCallout districtCode={code} districtName={district.district} />
</PageLayout>
