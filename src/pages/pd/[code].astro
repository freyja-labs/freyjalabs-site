---
/**
 * /pd/[code].astro — Dynamic district portal page
 * Reads from /src/data/district-portals.json
 * Route: freyjalabs.com/pd/77092-hisd, freyjalabs.com/pd/27518-wcpss, etc.
 */
import PageLayout from '../../layouts/PageLayout.astro';
import SectionLabel from '../../components/ui/SectionLabel.astro';
import DistrictMap from '../../components/icons/DistrictMap.astro';
import districtData from '../../data/district-portals.json';

export function getStaticPaths() {
  return Object.keys(districtData.districts).map(code => ({
    params: { code },
    props: {
      district: districtData.districts[code],
      meta: districtData.meta,
      states: districtData.states,
      stateContext: (districtData as any).stateContext?.[districtData.districts[code].state] || null,
    }
  }));
}

const { code } = Astro.params;
const { district, meta, states, stateContext } = Astro.props;
const { brand } = meta;
const stateStandards = states[district.state] || {};
const techLesson = district.lessons.tech;
const unpluggedLesson = district.lessons.unplugged;
const lessons = [
  { kind: 'tech', lesson: techLesson, accent: 'forest' },
  unpluggedLesson ? { kind: 'unplugged', lesson: unpluggedLesson, accent: 'earth' } : null,
].filter(Boolean);

const tierAccent: Record<string, string> = {
  cohort: 'border-forest/30 bg-forest/[0.04]',
  building: 'border-forest/30 bg-forest/[0.04]',
  institute: 'border-forest/40 bg-forest/[0.06]',
  leadership: 'border-earth/30 bg-earth/[0.04]',
  coaching: 'border-clay/30 bg-clay/[0.04]',
};
---

<PageLayout
  title={`${district.district} — Professional Development`}
  description={`Customized, hands-on professional development for ${district.district}. AI literacy, STEM integration, and computational thinking workshops built for your teachers and students.`}
  path={`/pd/${code}`}
>
  <!-- HERO with animated district map -->
  <section class="relative overflow-hidden bg-warm-white">
    <div class="absolute inset-0 z-0">
      <DistrictMap code={code} class="h-full w-full" label={`Animated street map of ${district.city}, ${district.state}`} />
    </div>
    <div class="relative z-10 px-8 pt-24 pb-28">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-block bg-warm-white/90 backdrop-blur-sm rounded-2xl px-8 py-10 border border-border/60 shadow-sm">
          <SectionLabel>{brand.name}</SectionLabel>
          <h1 class="font-serif text-4xl md:text-5xl font-medium text-ink leading-tight mb-6">
            Professional Development for {district.district}
          </h1>
          <p class="font-serif text-[22px] text-earth italic mb-4">
            Customized. Hands-on. Built for your teachers and your students.
          </p>
          <p class="text-[15px] text-muted">
            {district.city}, {district.state} · {district.enrollment?.toLocaleString()} students
          </p>
        </div>
      </div>
    </div>
    <p class="relative z-10 text-center text-[10px] font-mono tracking-widest uppercase text-faded/70 pb-3">
      Map data © OpenStreetMap contributors
    </p>
  </section>

  <!-- JUMP CARDS — what's on this page -->
  <section class="px-8 -mt-10 relative z-20">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-3 gap-4">
        <a href="#context" class="group p-6 bg-warm-white border border-border rounded-lg hover:border-forest/50 hover:-translate-y-1 hover:shadow-lg transition-all duration-200">
          <span class="font-mono text-[10px] tracking-widest uppercase text-forest mb-2 block">01 · Context</span>
          <h3 class="font-serif text-[20px] font-semibold text-ink mb-1 group-hover:text-forest transition-colors">Your District, Your Place</h3>
          <p class="text-[14px] leading-relaxed text-muted">What we know about {district.district} and the community you serve.</p>
        </a>
        <a href="#lessons" class="group p-6 bg-warm-white border border-border rounded-lg hover:border-forest/50 hover:-translate-y-1 hover:shadow-lg transition-all duration-200">
          <span class="font-mono text-[10px] tracking-widest uppercase text-forest mb-2 block">02 · Lessons</span>
          <h3 class="font-serif text-[20px] font-semibold text-ink mb-1 group-hover:text-forest transition-colors">Sample Lessons + Teacher Pack</h3>
          <p class="text-[14px] leading-relaxed text-muted">Two full lessons designed for your students — with facilitation notes, differentiation, and standards alignment.</p>
        </a>
        <a href="#engagements" class="group p-6 bg-warm-white border border-border rounded-lg hover:border-forest/50 hover:-translate-y-1 hover:shadow-lg transition-all duration-200">
          <span class="font-mono text-[10px] tracking-widest uppercase text-forest mb-2 block">03 · Engagements</span>
          <h3 class="font-serif text-[20px] font-semibold text-ink mb-1 group-hover:text-forest transition-colors">Five Ways to Work Together</h3>
          <p class="text-[14px] leading-relaxed text-muted">From a 15-teacher cohort to a 100-teacher district institute. Pick the size that fits.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- CONTEXT — synthesized narrative reading of the district -->
  <section id="context" class="px-8 py-24 scroll-mt-20">
    <div class="max-w-3xl mx-auto">
      <SectionLabel>Reading the moment</SectionLabel>
      <h2 class="font-serif text-3xl md:text-[42px] font-medium text-ink leading-tight mb-10">
        How we see your district
      </h2>

      {district.contextNarrative ? (
        <div class="prose-narrative">
          <p class="font-serif text-[20px] md:text-[22px] leading-[1.65] text-ink first-letter:font-serif first-letter:text-[64px] first-letter:font-semibold first-letter:text-forest first-letter:float-left first-letter:leading-[0.85] first-letter:mr-3 first-letter:mt-2">
            {district.contextNarrative}
          </p>
        </div>
      ) : district.connectionPoint && (
        <p class="font-serif text-[19px] leading-relaxed text-muted">
          {district.connectionPoint}
        </p>
      )}

      {(district.knownInitiatives || stateContext) && (
        <div class="mt-14 grid md:grid-cols-2 gap-4 not-prose">
          {district.knownInitiatives && (
            <div class="p-5 bg-cream border border-border rounded-lg">
              <span class="font-mono text-[10px] tracking-widest uppercase text-earth mb-2 block">Initiatives in motion</span>
              <p class="text-[14px] leading-relaxed text-muted">{district.knownInitiatives}</p>
            </div>
          )}
          {stateContext && (
            <div class="p-5 bg-cream border border-border rounded-lg">
              <span class="font-mono text-[10px] tracking-widest uppercase text-earth mb-3 block">{district.state} state landscape</span>
              <dl class="space-y-2 text-[13px]">
                {stateContext.aiLegislation && (
                  <div class="flex gap-3">
                    <dt class="font-mono text-[10px] tracking-widest uppercase text-faded shrink-0 w-20 pt-0.5">AI policy</dt>
                    <dd class="text-muted leading-snug">{stateContext.aiLegislation}</dd>
                  </div>
                )}
                {stateContext.csGradReq && (
                  <div class="flex gap-3">
                    <dt class="font-mono text-[10px] tracking-widest uppercase text-faded shrink-0 w-20 pt-0.5">CS req</dt>
                    <dd class="text-muted leading-snug">{stateContext.csGradReq}{stateContext.effectiveDate ? ` · ${stateContext.effectiveDate}` : ''}</dd>
                  </div>
                )}
                {stateContext.statePdFunding && (
                  <div class="flex gap-3">
                    <dt class="font-mono text-[10px] tracking-widest uppercase text-faded shrink-0 w-20 pt-0.5">Funding</dt>
                    <dd class="text-muted leading-snug">{stateContext.statePdFunding}</dd>
                  </div>
                )}
                {stateContext.readinessLevel && (
                  <div class="flex gap-3">
                    <dt class="font-mono text-[10px] tracking-widest uppercase text-faded shrink-0 w-20 pt-0.5">Stage</dt>
                    <dd class="text-muted leading-snug">{stateContext.readinessLevel}</dd>
                  </div>
                )}
              </dl>
            </div>
          )}
        </div>
      )}
    </div>
  </section>

  <!-- SAMPLE LESSONS -->
  <section id="lessons" class="bg-warm-white px-8 py-24 scroll-mt-20">
    <div class="max-w-4xl mx-auto">
      <SectionLabel>Sample Lessons</SectionLabel>
      <h2 class="font-serif text-3xl md:text-[42px] font-medium text-ink leading-tight mb-4">
        What Your Teachers Build in a Single Day
      </h2>
      <p class="text-[17px] leading-relaxed text-muted mb-14 max-w-3xl">
        These are examples of lessons designed for your students, in your community. Every participant in a Freyja Labs engagement builds their own — tailored to their grade level, their subject area, and their students' experience.
      </p>

      {lessons.map(({ kind, lesson, accent }) => {
        const accentClasses = accent === 'forest'
          ? { tag: 'text-forest-light bg-forest/10', objBullet: 'before:bg-forest', aiBorder: 'border-forest/20', aiText: 'text-forest', aiBullet: 'before:bg-forest-light', protoBg: 'bg-forest/5 border-forest/15', protoText: 'text-forest', protoTag: 'text-forest' }
          : { tag: 'text-earth bg-earth/10', objBullet: 'before:bg-earth', aiBorder: 'border-forest/20', aiText: 'text-forest', aiBullet: 'before:bg-forest-light', protoBg: 'bg-forest/5 border-forest/15', protoText: 'text-forest', protoTag: 'text-forest' };
        const tm = lesson.teacher_materials;
        return (
          <div class="p-9 bg-cream border border-border rounded-lg mb-8">
            <span class={`inline-block font-mono text-[10px] tracking-widest uppercase ${accentClasses.tag} px-3 py-1 rounded mb-4`}>
              {lesson.badge}
            </span>
            <h3 class="font-serif text-[26px] font-semibold text-ink mb-2">{lesson.title}</h3>
            <p class="font-mono text-xs tracking-widest uppercase text-earth mb-6">
              {lesson.grade_band} · {lesson.subjects.join(' / ')} · {lesson.duration_minutes} minutes
            </p>
            <p class="text-[17px] leading-relaxed text-muted mb-8">{lesson.overview}</p>

            <div class="grid md:grid-cols-2 gap-6 mb-8">
              <div class="p-6 bg-warm-white border border-border rounded-lg">
                <h4 class="font-sans text-[15px] font-semibold text-ink mb-3">Content Objectives</h4>
                <ul class="space-y-2">
                  {lesson.content_objectives.map(obj => (
                    <li class={`text-[15px] leading-relaxed text-muted pl-4 relative before:content-[''] before:absolute before:left-0 before:top-[10px] before:w-1.5 before:h-1.5 ${accentClasses.objBullet} before:rounded-full`}>{obj}</li>
                  ))}
                </ul>
              </div>
              <div class={`p-6 bg-warm-white border ${accentClasses.aiBorder} rounded-lg`}>
                <h4 class={`font-sans text-[15px] font-semibold ${accentClasses.aiText} mb-3`}>AI Literacy Objectives</h4>
                <ul class="space-y-2">
                  {lesson.ai_literacy_objectives.map(obj => (
                    <li class={`text-[15px] leading-relaxed text-muted pl-4 relative before:content-[''] before:absolute before:left-0 before:top-[10px] before:w-1.5 before:h-1.5 ${accentClasses.aiBullet} before:rounded-full`}>{obj}</li>
                  ))}
                </ul>
              </div>
            </div>

            <h4 class="font-sans text-[15px] font-semibold text-ink mb-4">
              {kind === 'unplugged' ? 'What Students Do — No Screens, No Devices' : 'What Students Do'}
            </h4>
            <div class="space-y-4 mb-8">
              {lesson.procedure.map(phase => {
                const note = tm?.facilitation_notes?.find(n => n.phase === phase.phase);
                return (
                  <div class="p-5 bg-warm-white border border-border rounded-lg">
                    <span class="font-mono text-[10px] tracking-widest uppercase text-earth">
                      Phase {phase.phase} · {phase.duration_minutes} min
                    </span>
                    <strong class="block font-sans text-[15px] font-semibold text-ink mt-1 mb-1">{phase.title}</strong>
                    <p class="text-[15px] leading-relaxed text-muted">{phase.description}</p>
                    {note && (
                      <div class="mt-4 pt-4 border-t border-border/60">
                        <span class="font-mono text-[10px] tracking-widest uppercase text-forest mb-2 block">Facilitation focus</span>
                        <p class="text-[14px] leading-relaxed text-muted mb-3">{note.focus}</p>
                        <span class="font-mono text-[10px] tracking-widest uppercase text-clay mb-2 block">Watch for</span>
                        <p class="text-[14px] leading-relaxed text-muted italic">{note.watch_for}</p>
                      </div>
                    )}
                  </div>
                );
              })}
            </div>

            {kind === 'tech' && lesson.check_the_machine && (
              <div class={`p-6 ${accentClasses.protoBg} border rounded-lg mb-8`}>
                <h4 class={`font-sans text-[15px] font-semibold ${accentClasses.protoText} mb-4`}>Check the Machine Protocol</h4>
                <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
                  {lesson.check_the_machine.map(step => (
                    <div class="p-4 bg-warm-white rounded-lg border border-border">
                      <strong class={`block font-mono text-[11px] tracking-widest uppercase ${accentClasses.protoTag} mb-2`}>
                        {step.step}. {step.label}
                      </strong>
                      <p class="text-[14px] leading-relaxed text-muted">{step.prompt}</p>
                    </div>
                  ))}
                </div>
              </div>
            )}

            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <h4 class="font-sans text-[15px] font-semibold text-ink mb-3">Materials</h4>
                <ul class="space-y-1.5">
                  {lesson.materials.map(m => (
                    <li class="text-[15px] leading-relaxed text-muted pl-4 relative before:content-[''] before:absolute before:left-0 before:top-[10px] before:w-1.5 before:h-1.5 before:bg-sand before:rounded-full">{m}</li>
                  ))}
                </ul>
              </div>
              <div>
                <h4 class="font-sans text-[15px] font-semibold text-ink mb-3">Assessment</h4>
                <p class="text-[15px] leading-relaxed text-muted mb-2">{lesson.assessment.description}</p>
                {lesson.assessment.criteria && (
                  <p class="text-[14px] leading-relaxed text-faded italic">{lesson.assessment.criteria}</p>
                )}
              </div>
            </div>

            {/* TEACHER MATERIALS — only renders when present */}
            {tm && (
              <div class="mt-10 pt-10 border-t-2 border-dashed border-border">
                <div class="flex items-baseline gap-3 mb-2">
                  <span class="font-mono text-[10px] tracking-widest uppercase text-forest">Teacher pack</span>
                  <span class="font-mono text-[10px] tracking-widest uppercase text-faded">— everything you need to teach this</span>
                </div>
                <h4 class="font-serif text-[22px] font-semibold text-ink mb-6">For the Facilitator</h4>

                <div class="grid md:grid-cols-2 gap-6 mb-8">
                  {tm.prior_knowledge && (
                    <div class="p-6 bg-warm-white border border-border rounded-lg">
                      <h5 class="font-sans text-[14px] font-semibold text-ink mb-3">Prior Knowledge Required</h5>
                      <ul class="space-y-1.5">
                        {tm.prior_knowledge.map(p => (
                          <li class="text-[14px] leading-relaxed text-muted pl-4 relative before:content-[''] before:absolute before:left-0 before:top-[8px] before:w-1.5 before:h-1.5 before:bg-earth before:rounded-full">{p}</li>
                        ))}
                      </ul>
                    </div>
                  )}
                  {tm.exit_ticket && (
                    <div class="p-6 bg-warm-white border border-forest/20 rounded-lg">
                      <h5 class="font-sans text-[14px] font-semibold text-forest mb-3">Exit Ticket</h5>
                      <p class="text-[14px] leading-relaxed text-ink italic mb-3">"{tm.exit_ticket.prompt}"</p>
                      <span class="font-mono text-[10px] tracking-widest uppercase text-faded mb-2 block">Look for</span>
                      <ul class="space-y-1">
                        {tm.exit_ticket.look_for.map(l => (
                          <li class="text-[13px] leading-relaxed text-muted pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-forest">{l}</li>
                        ))}
                      </ul>
                    </div>
                  )}
                </div>

                {tm.misconceptions && (
                  <div class="mb-8">
                    <h5 class="font-sans text-[14px] font-semibold text-ink mb-4">Anticipated Misconceptions</h5>
                    <div class="space-y-3">
                      {tm.misconceptions.map(m => (
                        <div class="p-5 bg-warm-white border border-border rounded-lg">
                          <p class="text-[14px] leading-relaxed text-clay font-serif italic mb-2">{m.misconception}</p>
                          <p class="text-[14px] leading-relaxed text-muted"><strong class="text-forest">→</strong> {m.response}</p>
                        </div>
                      ))}
                    </div>
                  </div>
                )}

                {tm.differentiation && (
                  <div class="mb-8">
                    <h5 class="font-sans text-[14px] font-semibold text-ink mb-4">Differentiation</h5>
                    <div class="grid md:grid-cols-2 gap-4">
                      <div class="p-5 bg-warm-white border border-border rounded-lg">
                        <span class="font-mono text-[10px] tracking-widest uppercase text-earth mb-2 block">Below grade</span>
                        <p class="text-[14px] leading-relaxed text-muted">{tm.differentiation.below_grade}</p>
                      </div>
                      <div class="p-5 bg-warm-white border border-border rounded-lg">
                        <span class="font-mono text-[10px] tracking-widest uppercase text-earth mb-2 block">At grade</span>
                        <p class="text-[14px] leading-relaxed text-muted">{tm.differentiation.at_grade}</p>
                      </div>
                      <div class="p-5 bg-warm-white border border-border rounded-lg">
                        <span class="font-mono text-[10px] tracking-widest uppercase text-earth mb-2 block">Above grade</span>
                        <p class="text-[14px] leading-relaxed text-muted">{tm.differentiation.above_grade}</p>
                      </div>
                      {tm.differentiation.multilingual_learners && (
                        <div class="p-5 bg-warm-white border border-forest/20 rounded-lg">
                          <span class="font-mono text-[10px] tracking-widest uppercase text-forest mb-2 block">Multilingual learners</span>
                          <p class="text-[14px] leading-relaxed text-muted">{tm.differentiation.multilingual_learners}</p>
                        </div>
                      )}
                    </div>
                  </div>
                )}

                {tm.slide_cues && (
                  <div class="mb-8">
                    <h5 class="font-sans text-[14px] font-semibold text-ink mb-4">Slide Cues — {tm.slide_cues.length} slides</h5>
                    <div class="grid sm:grid-cols-2 gap-3">
                      {tm.slide_cues.map(s => (
                        <div class="p-4 bg-warm-white border border-border rounded-lg">
                          <span class="font-mono text-[10px] tracking-widest uppercase text-faded">Slide {s.slide}</span>
                          <strong class="block font-sans text-[14px] font-semibold text-ink mt-1 mb-2">{s.title}</strong>
                          <ul class="space-y-1">
                            {s.talking_points.map(tp => (
                              <li class="text-[13px] leading-relaxed text-muted pl-3 relative before:content-['·'] before:absolute before:left-0 before:text-forest">{tp}</li>
                            ))}
                          </ul>
                        </div>
                      ))}
                    </div>
                  </div>
                )}

                {tm.standards_alignment && (
                  <div class="mb-8">
                    <h5 class="font-sans text-[14px] font-semibold text-ink mb-4">Standards Alignment</h5>
                    <div class="space-y-2">
                      {tm.standards_alignment.map(s => (
                        <div class="p-4 bg-warm-white border border-border rounded-lg">
                          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-1">
                            <span class="font-mono text-[11px] tracking-widest uppercase text-forest">{s.framework}</span>
                            <span class="font-mono text-[11px] text-clay">{s.code}</span>
                          </div>
                          <p class="text-[14px] leading-relaxed text-muted">{s.text}</p>
                        </div>
                      ))}
                    </div>
                  </div>
                )}

                {tm.family_letter && (
                  <div class="p-6 bg-cream border-l-4 border-forest rounded">
                    <span class="font-mono text-[10px] tracking-widest uppercase text-forest mb-3 block">Family / Guardian Letter — copy & paste, edit to fit</span>
                    <p class="font-serif text-[15px] leading-relaxed text-ink whitespace-pre-line">{tm.family_letter}</p>
                  </div>
                )}
              </div>
            )}
          </div>
        );
      })}
    </div>
  </section>

  <!-- ENGAGEMENT OPTIONS -->
  <section id="engagements" class="px-8 py-24 scroll-mt-20">
    <div class="max-w-5xl mx-auto">
      <SectionLabel>Engagement Options</SectionLabel>
      <h2 class="font-serif text-3xl md:text-[42px] font-medium text-ink leading-tight mb-4">
        How We Can Work Together
      </h2>
      <p class="text-[17px] leading-relaxed text-muted mb-12 max-w-3xl">
        From a 15-teacher cohort to a 100-teacher district institute, every Freyja Labs engagement holds the same standard: small tell, lots of do. Pick the size that fits — we scale facilitation, not philosophy.
      </p>
      <div class="grid md:grid-cols-2 gap-5">
        {district.engagementOptions.map(opt => {
          const accent = tierAccent[opt.tier] || 'border-border bg-warm-white';
          return (
            <div class={`p-7 border rounded-lg ${accent} hover:-translate-y-1 hover:shadow-lg transition-all duration-200`}>
              <div class="flex items-baseline justify-between gap-3 mb-1">
                <h3 class="font-serif text-[22px] font-semibold text-ink">{opt.name}</h3>
                <span class="font-mono text-[10px] tracking-widest uppercase text-faded shrink-0">{opt.duration}</span>
              </div>
              <p class="font-mono text-[11px] tracking-widest uppercase text-forest mb-4">{opt.participants}</p>
              <p class="text-[15px] leading-relaxed text-muted mb-4">{opt.description}</p>
              <p class="text-[14px] leading-relaxed text-muted">
                <strong class="text-ink">What you get:</strong> {opt.deliverables}
              </p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- CLOSING / CTA -->
  <section class="bg-forest px-8 py-24">
    <div class="max-w-3xl mx-auto text-center">
      <p class="font-serif text-[22px] md:text-[26px] text-warm-white leading-snug mb-8 italic">
        {meta.closing_line}
      </p>
      <div class="flex flex-col items-center gap-2 mb-6">
        {brand.founders.map(f => (
          <p class="text-white/75 text-[15px]">{f.name}, {f.credential}</p>
        ))}
      </div>
      <p class="font-serif text-[20px] text-warm-white font-medium mb-6">{brand.tagline}</p>
      <a
        href="mailto:hello@freyjalabs.com"
        class="inline-block rounded-md font-sans font-semibold transition-all duration-200 text-center bg-warm-white text-forest px-10 py-4 text-base hover:-translate-y-0.5 hover:shadow-lg"
      >
        hello@freyjalabs.com
      </a>
    </div>
  </section>
</PageLayout>
