---
import PageLayout from '../../layouts/PageLayout.astro';
import SectionLabel from '../../components/ui/SectionLabel.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<PageLayout
  title="Blog"
  description="Insights on STEM education, AI literacy, computational thinking, and professional development from the Freyja Labs team."
  path="/blog"
>
  <section class="px-8 pt-20 pb-24">
    <div class="max-w-3xl mx-auto">
      <SectionLabel>Blog</SectionLabel>
      <h1 class="font-serif text-4xl md:text-5xl font-medium text-ink leading-tight mb-14">
        Thinking out loud
      </h1>

      {posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-lg text-muted mb-2">Coming soon.</p>
          <p class="text-sm text-faded">We're working on our first posts. Check back soon.</p>
        </div>
      ) : (
        <div class="space-y-10">
          {posts.map(post => (
            <a href={`/blog/${post.id}`} class="block group">
              <article class="py-8 border-b border-border">
                <div class="flex items-center gap-3 mb-3">
                  <time class="text-sm text-faded" datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                  <span class="text-border">&middot;</span>
                  <span class="text-sm text-faded">{post.data.author}</span>
                </div>
                <h2 class="font-serif text-2xl font-medium text-ink group-hover:text-forest transition-colors mb-3">
                  {post.data.title}
                </h2>
                <p class="text-[15px] text-muted leading-relaxed mb-3">{post.data.excerpt}</p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {post.data.tags.map(tag => (
                      <span class="font-mono text-[10px] tracking-widest uppercase px-3 py-1 bg-cream border border-border rounded-full text-forest-light">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </article>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</PageLayout>
