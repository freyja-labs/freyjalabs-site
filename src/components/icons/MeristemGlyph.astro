---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class={className}>
  <svg viewBox="0 0 320 320" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <!-- Background circles -->
    <circle cx="160" cy="160" r="150" fill="none" stroke="#DDD5C8" stroke-width="1" opacity="0.5"/>
    <circle cx="160" cy="160" r="100" fill="none" stroke="#DDD5C8" stroke-width="0.5" opacity="0.3"/>

    <!-- Main stem -->
    <line x1="160" y1="280" x2="160" y2="80" stroke="#3D6B4F" stroke-width="3" stroke-linecap="round" class="stem-line"/>

    <!-- Branch stems -->
    <line x1="160" y1="220" x2="120" y2="190" stroke="#3D6B4F" stroke-width="2" stroke-linecap="round" class="stem-line" style="animation-delay: 0.5s"/>
    <line x1="160" y1="180" x2="200" y2="150" stroke="#3D6B4F" stroke-width="2" stroke-linecap="round" class="stem-line" style="animation-delay: 0.7s"/>
    <line x1="160" y1="140" x2="125" y2="115" stroke="#3D6B4F" stroke-width="2" stroke-linecap="round" class="stem-line" style="animation-delay: 0.9s"/>

    <!-- Leaves -->
    <ellipse cx="108" cy="183" rx="18" ry="10" fill="#5A8E6D" opacity="0.7" transform="rotate(-30 108 183)" class="leaf" style="animation-delay: 0.8s"/>
    <ellipse cx="212" cy="143" rx="18" ry="10" fill="#5A8E6D" opacity="0.7" transform="rotate(30 212 143)" class="leaf" style="animation-delay: 1.1s"/>
    <ellipse cx="113" cy="108" rx="16" ry="9" fill="#5A8E6D" opacity="0.7" transform="rotate(-25 113 108)" class="leaf" style="animation-delay: 1.4s"/>
    <ellipse cx="160" cy="75" rx="20" ry="12" fill="#3D6B4F" opacity="0.8" class="leaf" style="animation-delay: 1.7s"/>

    <!-- Growth points -->
    <circle cx="160" cy="72" r="6" fill="#3D6B4F" class="growth-point"/>
    <circle cx="108" cy="183" r="4" fill="#5A8E6D" class="growth-point" style="animation-delay: 0.8s"/>
    <circle cx="212" cy="143" r="4" fill="#5A8E6D" class="growth-point" style="animation-delay: 1.6s"/>

    <!-- Root system -->
    <line x1="160" y1="280" x2="130" y2="310" stroke="#6B5B3E" stroke-width="1.5" stroke-linecap="round" opacity="0.4" class="stem-line" style="animation-delay: 0.3s"/>
    <line x1="160" y1="280" x2="190" y2="305" stroke="#6B5B3E" stroke-width="1.5" stroke-linecap="round" opacity="0.4" class="stem-line" style="animation-delay: 0.4s"/>
    <line x1="160" y1="280" x2="155" y2="315" stroke="#6B5B3E" stroke-width="1" stroke-linecap="round" opacity="0.3" class="stem-line" style="animation-delay: 0.5s"/>
  </svg>
</div>
