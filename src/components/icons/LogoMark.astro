---
/**
 * LogoMark.astro — inline meristem flower mark.
 * Source: brand/logos/svg/logo-mark.svg
 */
interface Props {
  size?: number;
  class?: string;
  variant?: 'color' | 'white';
}
const { size = 32, class: className = '', variant = 'color' } = Astro.props;
const stem = variant === 'white' ? '#FFFEF9' : '#3D6B4F';
const leaf = variant === 'white' ? 'rgba(255,254,249,0.85)' : '#5A8E6D';
const center = variant === 'white' ? '#3D6B4F' : '#FAF7F2';
const dot = variant === 'white' ? '#FFFEF9' : '#3D6B4F';
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 200 200"
  width={size}
  height={size}
  class={className}
  aria-hidden="true"
>
  <circle cx="100" cy="100" r="15" fill={stem} />
  <ellipse cx="100" cy="70" rx="18" ry="10" fill={leaf} opacity="0.85" transform="rotate(-15 100 70)" />
  <ellipse cx="130" cy="85" rx="20" ry="11" fill={leaf} opacity="0.75" transform="rotate(50 130 85)" />
  <ellipse cx="125" cy="125" rx="22" ry="12" fill={leaf} opacity="0.65" transform="rotate(115 125 125)" />
  <ellipse cx="85" cy="135" rx="25" ry="12" fill={leaf} opacity="0.55" transform="rotate(180 85 135)" />
  <ellipse cx="65" cy="100" rx="25" ry="12" fill={leaf} opacity="0.45" transform="rotate(245 65 100)" />
  <circle cx="100" cy="100" r="8" fill={center} />
  <circle cx="100" cy="100" r="4" fill={dot} />
</svg>
