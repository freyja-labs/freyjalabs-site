---
import Button from '../ui/Button.astro';
---

<section class="bg-forest px-8 py-24 text-center">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-serif text-3xl md:text-[42px] font-medium text-warm-white leading-tight mb-4">Ready to start?</h2>
    <p class="text-[17px] text-white/75 leading-relaxed max-w-lg mx-auto mb-9">
      Every engagement begins with a conversation. Tell us about your context, your goals, and your challenges &mdash; and we'll design something that fits.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <Button href="mailto:hello@freyjalabs.com" variant="light">hello@freyjalabs.com</Button>
      <a
        href="https://calendly.com/drmikeb/freyja-labs-meet-greet"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block rounded-md font-sans font-semibold transition-all duration-200 text-center border-2 border-warm-white text-warm-white px-10 py-4 text-base hover:bg-warm-white hover:text-forest"
      >
        Schedule a meeting
      </a>
    </div>
  </div>
</section>
