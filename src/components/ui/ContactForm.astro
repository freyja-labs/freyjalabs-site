---
const hearAboutOptions = [
  'Referral from a colleague',
  'Conference or event',
  'Web search',
  'Social media',
  'Other',
];

const interestOptions = [
  'Custom Workshops',
  'District Consulting',
  'Train-the-Trainer',
  'Virtual & Hybrid',
  'Something else',
];
---

<form
  action="https://formspree.io/f/mnjwnjee"
  method="POST"
  class="space-y-6"
>
  <div class="grid md:grid-cols-2 gap-6">
    <div>
      <label for="name" class="block text-sm font-medium text-ink mb-2">Name</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        class="w-full px-4 py-3 bg-warm-white border border-border rounded-md text-ink text-[15px] focus:outline-none focus:ring-2 focus:ring-forest focus:border-transparent transition-colors"
      />
    </div>
    <div>
      <label for="email" class="block text-sm font-medium text-ink mb-2">Email</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="w-full px-4 py-3 bg-warm-white border border-border rounded-md text-ink text-[15px] focus:outline-none focus:ring-2 focus:ring-forest focus:border-transparent transition-colors"
      />
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6">
    <div>
      <label for="organization" class="block text-sm font-medium text-ink mb-2">Organization</label>
      <input
        type="text"
        id="organization"
        name="organization"
        class="w-full px-4 py-3 bg-warm-white border border-border rounded-md text-ink text-[15px] focus:outline-none focus:ring-2 focus:ring-forest focus:border-transparent transition-colors"
      />
    </div>
    <div>
      <label for="role" class="block text-sm font-medium text-ink mb-2">Role</label>
      <input
        type="text"
        id="role"
        name="role"
        class="w-full px-4 py-3 bg-warm-white border border-border rounded-md text-ink text-[15px] focus:outline-none focus:ring-2 focus:ring-forest focus:border-transparent transition-colors"
      />
    </div>
  </div>

  <fieldset>
    <legend class="block text-sm font-medium text-ink mb-3">Interested in <span class="text-faded font-normal">(select any that apply)</span></legend>
    <div class="grid sm:grid-cols-2 gap-2.5">
      {interestOptions.map(option => (
        <label class="flex items-start gap-3 px-4 py-3 bg-warm-white border border-border rounded-md cursor-pointer hover:border-forest-light transition-colors has-[:checked]:border-forest has-[:checked]:bg-forest/5">
          <input
            type="checkbox"
            name="interests[]"
            value={option}
            class="mt-0.5 h-4 w-4 accent-forest cursor-pointer"
          />
          <span class="text-[15px] text-ink leading-snug">{option}</span>
        </label>
      ))}
    </div>
  </fieldset>

  <div>
    <label for="message" class="block text-sm font-medium text-ink mb-2">Message</label>
    <textarea
      id="message"
      name="message"
      rows="5"
      required
      class="w-full px-4 py-3 bg-warm-white border border-border rounded-md text-ink text-[15px] focus:outline-none focus:ring-2 focus:ring-forest focus:border-transparent transition-colors resize-y"
    ></textarea>
  </div>

  <div>
    <label for="referral" class="block text-sm font-medium text-ink mb-2">How did you hear about us? <span class="text-faded font-normal">(optional)</span></label>
    <select
      id="referral"
      name="referral"
      class="w-full px-4 py-3 bg-warm-white border border-border rounded-md text-ink text-[15px] focus:outline-none focus:ring-2 focus:ring-forest focus:border-transparent transition-colors"
    >
      <option value="">Select an option</option>
      {hearAboutOptions.map(option => (
        <option value={option}>{option}</option>
      ))}
    </select>
  </div>

  <button
    type="submit"
    class="bg-forest text-warm-white px-8 py-3.5 rounded-md font-sans font-semibold text-[15px] hover:bg-forest-dark transition-colors cursor-pointer"
  >
    Send Message
  </button>
</form>
