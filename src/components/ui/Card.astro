---
interface Props {
  href?: string;
  class?: string;
}
const { href, class: className = '' } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={[
    'block p-9 bg-warm-white border border-border rounded-lg transition-all duration-200 hover:-translate-y-1 hover:shadow-lg hover:border-forest/30',
    className,
  ]}
>
  <slot />
</Tag>
